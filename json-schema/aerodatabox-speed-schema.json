      "format": "double"
    },
    "meterPerSecond": {
      "type": "number",
      "description": "Speed in meters per second",
      "format": "double"
    }
  },
  "required": [
    "kmPerHour",
    "kt",
    "meterPerSecond",
    "miPerHour"
